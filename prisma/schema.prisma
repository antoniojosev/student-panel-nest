generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  instructor
}

enum StudentStatus {
  activo
  inactivo
  completado
  abandonado
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(instructor)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]
}

model Student {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  institution    String
  course         String
  progress       Int           @default(0)
  status         StudentStatus @default(activo)
  registeredAt   DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  instructorId   String
  instructor     User          @relation(fields: [instructorId], references: [id])
}
