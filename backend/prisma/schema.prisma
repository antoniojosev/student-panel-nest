generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("instructor") // admin | instructor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students Student[]
}

model Student {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  institution    String
  course         String
  progress       Int      @default(0)
  status         String   @default("activo") // activo | inactivo | completado | abandonado
  registeredAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  instructorId   String
  instructor     User     @relation(fields: [instructorId], references: [id])
}
